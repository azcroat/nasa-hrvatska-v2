<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Apple Privacy Manifest — required for all apps submitted to App Store (iOS 17+)
  Place this file inside your Xcode project (add it to the app target).

  Naša Hrvatska accesses the following privacy-relevant APIs and data:
  - NSPrivacyAccessedAPICategoryUserDefaults  : localStorage / sessionStorage (progress, session, family data)
  - NSPrivacyAccessedAPICategoryDiskSpace     : Firebase SDK internal cache, Dexie/IndexedDB offline cache

  Third-party APIs that receive user data:
  - Firebase (Google)       : email, display name, learning progress, family group data
  - ElevenLabs              : text phrases for TTS audio generation (not stored)
  - Microsoft Azure Speech  : text phrases for TTS audio generation (not stored, fallback only)
  - Anthropic Claude API    : user-written text for AI writing corrections (not stored)
  - Resend                  : support ticket content + user display name/email
  - Plausible Analytics     : privacy-first, cookie-free page analytics (no PII)

  Family groups are parent-managed. A parent/guardian creates the group and
  enrolls minor members, providing consent for their data to be shared within
  the family group (display name + XP visible to group members only).
-->
<plist version="1.0">
<dict>
  <key>NSPrivacyAccessedAPITypes</key>
  <array>

    <!-- localStorage / sessionStorage — stores learning progress, user session, family group -->
    <dict>
      <key>NSPrivacyAccessedAPIType</key>
      <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
      <key>NSPrivacyAccessedAPITypeReasons</key>
      <array>
        <string>CA92.1</string>
      </array>
    </dict>

    <!-- Dexie / IndexedDB offline cache, Firebase SDK internal storage -->
    <dict>
      <key>NSPrivacyAccessedAPIType</key>
      <string>NSPrivacyAccessedAPICategoryDiskSpace</string>
      <key>NSPrivacyAccessedAPITypeReasons</key>
      <array>
        <string>85F4.1</string>
      </array>
    </dict>

  </array>

  <!-- No cross-app tracking. Plausible Analytics is cookie-free and does not use device identifiers. -->
  <key>NSPrivacyTracking</key>
  <false/>

  <key>NSPrivacyTrackingDomains</key>
  <array/>

  <key>NSPrivacyCollectedDataTypes</key>
  <array>

    <!-- Email address — Firebase Authentication, family group membership, support tickets -->
    <dict>
      <key>NSPrivacyCollectedDataType</key>
      <string>NSPrivacyCollectedDataTypeEmailAddress</string>
      <key>NSPrivacyCollectedDataTypeLinked</key>
      <true/>
      <key>NSPrivacyCollectedDataTypeTracking</key>
      <false/>
      <key>NSPrivacyCollectedDataTypePurposes</key>
      <array>
        <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
      </array>
    </dict>

    <!-- Display name — shown on family leaderboard, included in support tickets -->
    <dict>
      <key>NSPrivacyCollectedDataType</key>
      <string>NSPrivacyCollectedDataTypeName</string>
      <key>NSPrivacyCollectedDataTypeLinked</key>
      <true/>
      <key>NSPrivacyCollectedDataTypeTracking</key>
      <false/>
      <key>NSPrivacyCollectedDataTypePurposes</key>
      <array>
        <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
      </array>
    </dict>

    <!-- Learning progress (XP, lesson completions, streak, spaced-repetition data) — Firebase Firestore -->
    <dict>
      <key>NSPrivacyCollectedDataType</key>
      <string>NSPrivacyCollectedDataTypeOtherUserContent</string>
      <key>NSPrivacyCollectedDataTypeLinked</key>
      <true/>
      <key>NSPrivacyCollectedDataTypeTracking</key>
      <false/>
      <key>NSPrivacyCollectedDataTypePurposes</key>
      <array>
        <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
      </array>
    </dict>

    <!-- User-written text sent to Anthropic Claude API for Croatian writing corrections.
         Text is not stored after the correction response is returned. -->
    <dict>
      <key>NSPrivacyCollectedDataType</key>
      <string>NSPrivacyCollectedDataTypeOtherDiagnosticData</string>
      <key>NSPrivacyCollectedDataTypeLinked</key>
      <false/>
      <key>NSPrivacyCollectedDataTypeTracking</key>
      <false/>
      <key>NSPrivacyCollectedDataTypePurposes</key>
      <array>
        <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
      </array>
    </dict>

    <!-- Support ticket content (subject, description, optional reply email) sent via Resend -->
    <dict>
      <key>NSPrivacyCollectedDataType</key>
      <string>NSPrivacyCollectedDataTypeCustomerSupport</string>
      <key>NSPrivacyCollectedDataTypeLinked</key>
      <true/>
      <key>NSPrivacyCollectedDataTypeTracking</key>
      <false/>
      <key>NSPrivacyCollectedDataTypePurposes</key>
      <array>
        <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
      </array>
    </dict>

  </array>
</dict>
</plist>
