{
  "compilerOptions": {
    // Target modern browsers (Cloudflare Pages / PWA)
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",

    // allowJs: include .jsx files in the compilation so .ts files can import them.
    // checkJs: false so only explicitly-converted .ts/.tsx files get type-checked.
    // Add /* @ts-check */ to individual .jsx files once they're ready.
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,

    // JSX support
    "jsx": "react-jsx",

    // Strict mode: enabled. Files with @ts-nocheck are unaffected — errors
    // surface as @ts-nocheck is removed per batch in SP3 Tasks 4–14.
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "strictNullChecks": true,

    // Catch the class of bug that burned us: accessing undefined props
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    // Vite types: import.meta.env, import.meta.hot, etc.
    "types": ["vite/client"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "scripts", "src/tests/**/*"]
}
