rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────
    // The app uses email (with special chars replaced by _) as the document ID.
    // Mirror of the JS regex: uid.replace(/[.#$/\[\]]/g, '_')
    //
    // IMPORTANT: Firestore Rules replace() treats the first arg as a RE2 regex,
    // NOT a literal string. Special regex chars must be escaped with backslash:
    //   '\\.'  = literal dot   (plain '.' would match ANY character)
    //   '\\$'  = literal $     (plain '$' would match end-of-string)
    //   '\\['  = literal [     (plain '[' is an invalid regex that causes an error)
    //   '\\]'  = literal ]     (plain ']' is an invalid regex)
    // Chaining 6 calls on '\\.' handles up to 6 dots (enough for any email).
    function emailToId(email) {
      return email.replace('\\.','_').replace('\\.','_').replace('\\.','_')
                  .replace('\\.','_').replace('\\.','_').replace('\\.','_')
                  .replace('#','_').replace('\\$','_')
                  .replace('\\[','_').replace('\\]','_').replace('/','_');
    }

    function isOwner(userId) {
      return request.auth != null && (
        request.auth.uid == userId ||
        emailToId(request.auth.token.email) == userId
      );
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns true if the authenticated user's email appears in a flat email list.
    // Family documents store memberEmails (string[]) alongside the full members array
    // so Firestore rules can enforce membership without iterating over maps.
    function isFamilyMember(memberEmails) {
      return request.auth.token.email in memberEmails;
    }

    // ─── XP validation helpers ─────────────────────────────────────────────

    // User-doc UPDATE: top-level xp field must be non-negative integer.
    // No per-write increment cap — a user may sync accumulated offline XP in one
    // batch (e.g. 20 lessons × 50 XP = 1000 XP). The cap was silently blocking
    // legitimate cross-device sync writes, causing divergent state across devices.
    // Anti-cheat protection: XP can never decrease (except an explicit reset to 0),
    // total cap enforced at 100,000 XP (well above any legitimate learner), and the
    // progress blob size is separately capped at 200 KB.
    function validXpUpdate() {
      let oldXp = resource.data.get('xp', 0);
      let newXp = request.resource.data.get('xp', oldXp);
      return newXp >= 0
        && newXp == int(newXp)
        && (newXp >= oldXp || newXp == 0)
        && newXp <= 100000;
    }

    // User-doc UPDATE: progress blob must be ≤ 200 KB to prevent abuse.
    // The full user progress JSON is typically 2-8 KB; 200 KB is a generous ceiling.
    // Uses .get() so writes that don't include progress are always allowed.
    function validProgressSize() {
      let prog = request.resource.data.get('progress', '');
      return prog == '' || prog.size() <= 204800;
    }

    // Leaderboard CREATE: caps match UPDATE caps — a user syncing accumulated offline
    // XP on their first leaderboard write must not be blocked by an artificial low cap.
    function validLbXpCreate() {
      return request.resource.data.xp >= 0
        && request.resource.data.xp <= 100000;
    }
    function validLbLcCreate() {
      return request.resource.data.lc >= 0
        && request.resource.data.lc <= 10000;
    }

    // Leaderboard UPDATE: XP must never decrease (except reset to 0); no per-write cap.
    // Removing the +500/+10 increment caps — same reasoning as validXpUpdate above:
    // offline sync can accumulate large increments that must be written in one batch.
    function validLbXpUpdate() {
      let oldXp = resource.data.get('xp', 0);
      let newXp = request.resource.data.xp;
      return newXp >= 0
        && newXp == int(newXp)
        && (newXp >= oldXp || newXp == 0)
        && newXp <= 100000;
    }
    function validLbLcUpdate() {
      let oldLc = resource.data.get('lc', 0);
      let newLc = request.resource.data.lc;
      return newLc >= 0
        && newLc >= oldLc
        && newLc <= 10000;
    }

    // ─── User documents ────────────────────────────────────────────────────
    // Owner reads/writes their own document only.
    // UPDATE validates the top-level xp field to prevent client-side XP inflation.
    // CREATE is ownership-only (resource.data doesn't exist yet; XP bounded by first UPDATE).
    // FRIEND EXCEPTION: any authenticated user may update ONLY the friendUids field on
    // any user document — required for bidirectional friend add/remove (fbAddFriend,
    // fbRemoveFriend write arrayUnion/arrayRemove to both participants' docs).
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && validXpUpdate() && validProgressSize()
        || (isAuthenticated()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friendUids']));
      allow delete: if false;
    }

    // ─── Public profiles ───────────────────────────────────────────────────
    // Lightweight public stats used by the friend leaderboard.
    // Written by fbSaveProgress alongside /users/{uid} (owner-only).
    // Readable by all authenticated users so friends can see each other's stats.
    // Schema: { name, xp, lc, streak, level, lastActive }
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && request.resource.data.keys().hasAll(['name', 'xp', 'lc', 'streak', 'level', 'lastActive'])
        && request.resource.data.xp >= 0
        && request.resource.data.lc >= 0
        && request.resource.data.level >= 1;
      allow delete: if false;
    }

    // ─── Friend codes ──────────────────────────────────────────────────────
    // Lookup index: 6-char code → { uid, name, updated }.
    // Written by fbRegisterFriendCode on every sign-in (upsert).
    // Read by any authenticated user to resolve a code during friend-add.
    // A user may only register a code that maps to their own UID.
    match /friendCodes/{code} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated()
        && request.resource.data.keys().hasAll(['uid', 'name', 'updated'])
        && (request.resource.data.uid == request.auth.uid
            || request.resource.data.uid == emailToId(request.auth.token.email));
      allow delete: if false;
    }

    // ─── Leaderboard ──────────────────────────────────────────────────────
    // Split into create/update so resource.data (old doc) is only accessed on UPDATE.
    // XP and lc increments are capped per write to prevent leaderboard stuffing.
    match /leaderboard/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId)
        && validLbXpCreate()
        && validLbLcCreate();
      allow update: if isOwner(userId)
        && validLbXpUpdate()
        && validLbLcUpdate();
    }

    // ─── Family groups ─────────────────────────────────────────────────────
    match /families/{familyCode} {
      // get: any authenticated user can fetch a specific family doc by code.
      //   Required for join-code validation — a user must read the doc to confirm
      //   the code exists and retrieve the family name before writing themselves in.
      // list: disabled — no client path queries across multiple family docs.
      allow get: if isAuthenticated();
      allow list: if false;

      // Creator must be the sole initial member and include memberEmails for rule enforcement
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['name', 'code', 'created', 'members', 'memberEmails'])
        && request.resource.data.members.size() == 1
        && request.resource.data.memberEmails.size() == 1
        && request.auth.token.email in request.resource.data.memberEmails;

      // Existing members can update (leave/rename). New users can join by adding their own email.
      // memberEmails flat list enables O(1) membership check without map iteration.
      // Join case: user is not yet in memberEmails but IS adding their email to the new list.
      allow update: if isAuthenticated()
        && (isFamilyMember(resource.data.memberEmails)
            || request.auth.token.email in request.resource.data.memberEmails)
        && request.resource.data.keys().hasAll(['name', 'code', 'created', 'members', 'memberEmails'])
        && request.resource.data.members.size() <= 50
        && request.resource.data.memberEmails.size() <= 50
        && resource.data.created == request.resource.data.created
        && resource.data.code == request.resource.data.code;

      allow delete: if false;

      // ─── Reactions subcollection ──────────────────────────────────────
      // Any authenticated family member can read and write reactions.
      // Keyed by achievementKey — one reaction document per achievement.
      match /reactions/{reactionId} {
        allow read: if isAuthenticated()
          && isFamilyMember(get(/databases/$(database)/documents/families/$(familyCode)).data.memberEmails);
        allow create, update: if isAuthenticated()
          && isFamilyMember(get(/databases/$(database)/documents/families/$(familyCode)).data.memberEmails);
        allow delete: if false;
      }
    }

    // ─── Weekly leaderboard subcollection ────────────────────────────────
    // /leaderboard/{weekKey}/entries/{uid} — per-week XP entries.
    // Only the owner may write their own entry; any authenticated user may read.
    match /leaderboard/{weekKey}/entries/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId)
        && validLbXpCreate()
        && validLbLcCreate();
      allow update: if isOwner(userId)
        && validLbXpUpdate()
        && validLbLcUpdate();
    }

    // ─── Deny everything else ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
