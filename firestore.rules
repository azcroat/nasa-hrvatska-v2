rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────
    // The app uses email (with special chars replaced by _) as the document ID.
    // Mirror of the JS regex: uid.replace(/[.#$/\[\]]/g, '_')
    //
    // IMPORTANT: Firestore Rules replace() treats the first arg as a RE2 regex,
    // NOT a literal string. Special regex chars must be escaped with backslash:
    //   '\\.'  = literal dot   (plain '.' would match ANY character)
    //   '\\$'  = literal $     (plain '$' would match end-of-string)
    //   '\\['  = literal [     (plain '[' is an invalid regex that causes an error)
    //   '\\]'  = literal ]     (plain ']' is an invalid regex)
    // Chaining 6 calls on '\\.' handles up to 6 dots (enough for any email).
    function emailToId(email) {
      return email.replace('\\.','_').replace('\\.','_').replace('\\.','_')
                  .replace('\\.','_').replace('\\.','_').replace('\\.','_')
                  .replace('#','_').replace('\\$','_')
                  .replace('\\[','_').replace('\\]','_').replace('/','_');
    }

    function isOwner(userId) {
      return request.auth != null && (
        request.auth.uid == userId ||
        emailToId(request.auth.token.email) == userId
      );
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // ─── XP validation helpers ─────────────────────────────────────────────

    // User-doc UPDATE: top-level xp field must be non-negative integer.
    // No per-write increment cap — a user may sync accumulated offline XP in one
    // batch (e.g. 20 lessons × 50 XP = 1000 XP). The cap was silently blocking
    // legitimate cross-device sync writes, causing divergent state across devices.
    // Anti-cheat protection: XP can never decrease (except an explicit reset to 0),
    // total cap enforced at 100,000 XP (well above any legitimate learner), and the
    // progress blob size is separately capped at 200 KB.
    function validXpUpdate() {
      let oldXp = resource.data.get('xp', 0);
      let newXp = request.resource.data.get('xp', oldXp);
      return newXp >= 0
        && newXp == int(newXp)
        && (newXp >= oldXp || newXp == 0)
        && newXp <= 100000
        && (newXp - oldXp) <= 1000;  // per-write backstop; blocks extreme offline manipulation
    }

    // User-doc UPDATE: progress blob must be ≤ 200 KB to prevent abuse.
    // The full user progress JSON is typically 2-8 KB; 200 KB is a generous ceiling.
    // Uses .get() so writes that don't include progress are always allowed.
    function validProgressSize() {
      let prog = request.resource.data.get('progress', '');
      return prog == '' || prog.size() <= 204800;
    }

    // User-doc UPDATE: levelQuizPasses must be a map when present.
    // Optional field — absent on existing users (no entry) is always valid.
    // The field lives inside the progress JSON blob; this guard covers any future
    // path that writes it as a top-level Firestore field.
    function validLevelQuizPasses() {
      return !('levelQuizPasses' in request.resource.data)
          || request.resource.data.levelQuizPasses is map;
    }

    // FRIEND-EXCEPTION GUARD: when a non-owner writes friendUids on someone else's
    // user doc, restrict the change to ONLY adding or removing the writer's OWN UID.
    // Without this, any authenticated user could replace the target's friendUids array
    // wholesale — bloat it past the 200KB progress cap (DoS), or wipe the target's
    // friend list entirely.
    //
    // Allowed diffs (set semantics):
    //   added   == {request.auth.uid} AND removed == {}    (writer adds self)
    //   removed == {request.auth.uid} AND added   == {}    (writer removes self)
    //
    // Rejects: replacing array contents, adding multiple UIDs, adding someone
    // else's UID, removing UIDs other than the writer's own.
    function isFriendUidDiffSelf() {
      let oldList = resource.data.get('friendUids', []);
      let newList = request.resource.data.get('friendUids', []);
      let added   = newList.toSet().difference(oldList.toSet());
      let removed = oldList.toSet().difference(newList.toSet());
      let selfSet = [request.auth.uid].toSet();
      return (added == selfSet && removed.size() == 0)
          || (removed == selfSet && added.size() == 0);
    }

    // ─── User documents ────────────────────────────────────────────────────
    // Owner reads/writes their own document only.
    // UPDATE validates the top-level xp field to prevent client-side XP inflation.
    // CREATE is ownership-only (resource.data doesn't exist yet; XP bounded by first UPDATE).
    // FRIEND EXCEPTION: any authenticated user may update ONLY the friendUids field on
    // any user document — required for bidirectional friend add/remove (fbAddFriend,
    // fbRemoveFriend write arrayUnion/arrayRemove to both participants' docs).
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && validXpUpdate() && validProgressSize() && validLevelQuizPasses()
        || (isAuthenticated()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friendUids'])
            && isFriendUidDiffSelf());
      allow delete: if false;
    }

    // ─── Public profiles ───────────────────────────────────────────────────
    // Lightweight stats, written by fbSaveProgress alongside /users/{uid}.
    // SECURITY (2026-06-06): read locked to owner-only. The previous
    // `allow read: if isAuthenticated()` let ANY signed-in user enumerate the
    // whole collection and harvest every user's email-derived doc ID + display
    // name + stats — an authenticated-wide PII / GDPR exposure. No client code
    // reads this collection except the admin dashboard (which must move
    // server-side behind an Admin-SDK custom claim); the "friends see each
    // other's stats" feature was never actually wired to a profiles read.
    // Friend-scoped reads require re-keying profiles by the opaque Firebase uid
    // first (email-as-doc-id can't be matched against request.auth.uid in
    // rules) — see the Phase-1 migration plan. Until then: owner-only.
    // Schema: { name, xp, lc, streak, level, lastActive }
    match /profiles/{userId} {
      allow read: if isOwner(userId);
      // CREATE: enforce same shape + XP/lc bounds as UPDATE.
      // level validation mirrors UPDATE (int 1-6 or CEFR string for legacy writes).
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['name', 'xp', 'lc', 'streak', 'level', 'lastActive'])
        && request.resource.data.xp >= 0
        && request.resource.data.xp <= 100000
        && request.resource.data.lc >= 0
        && request.resource.data.lc <= 10000
        && (request.resource.data.level is int
            ? (request.resource.data.level >= 1 && request.resource.data.level <= 6)
            : request.resource.data.level in ['A1', 'A2', 'B1', 'B2', 'C1', 'C2']);
      allow update: if isOwner(userId)
        && request.resource.data.keys().hasAll(['name', 'xp', 'lc', 'streak', 'level', 'lastActive'])
        && request.resource.data.xp >= 0
        && request.resource.data.xp <= 100000
        && request.resource.data.lc >= 0
        && request.resource.data.lc <= 10000
        // level is always a number 1-6 (A1→1 … C2→6) after the CEFR mapping in fbSaveProgress.
        // Accept int in range 1-6, OR one of the canonical CEFR strings for legacy writes.
        // Rejecting arbitrary strings closes a low-value injection vector.
        && (request.resource.data.level is int
            ? (request.resource.data.level >= 1 && request.resource.data.level <= 6)
            : request.resource.data.level in ['A1', 'A2', 'B1', 'B2', 'C1', 'C2']);
      allow delete: if false;
    }

    // ─── SRS (Spaced Repetition) — separate collection to avoid 200KB blob limit ─
    // Owner-only read/write; no size cap (SRS data is compact JSON, ~10-50KB).
    // Schema: { cards(map), updated(timestamp) } — written by fbSaveSRS with merge:false.
    // delete is allowed separately (without shape check) for fbDeleteAccount cleanup.
    match /srs/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.keys().hasAll(['cards', 'updated']);
      allow delete: if isOwner(userId);
    }

    // ─── XP audit log — written by offlineAwardQueue.flush() on reconnect ────
    // Append-only: any authenticated owner may write; nobody may read (admin only).
    // Suspicious offline XP amounts are flagged here for manual review.
    match /users/{userId}/xpAudit/{auditId} {
      allow read: if false;
      allow write: if isOwner(userId);
      allow delete: if false;
    }

    // ─── Conversation memory — Maja's per-user session summaries ──────────────
    // Written by useConversationMemory after each AI Conversation session.
    // Schema: { ts(number), level(string), scenario(string), score(int 0–100),
    //           struggles(string[]), vocab(string[]), turns(int) }
    // Injected into Maja's system prompt at session start for personalised responses.
    match /users/{userId}/conversationMemory/{docId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.keys().hasAll(['ts', 'level', 'score', 'turns'])
        && request.resource.data.ts   is number
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100
        && request.resource.data.turns is int
        && request.resource.data.turns >= 0;
      allow delete: if false;
    }

    // ─── Deny everything else ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
