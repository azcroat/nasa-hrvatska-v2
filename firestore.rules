rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────
    // The app uses email (with special chars replaced by _) as the document ID
    function emailToId(email) {
      // Chain 6 replaces to handle up to 6 dots in local-part (covers all real-world emails).
      // Firestore Rules don't support regex global replace, so we chain calls.
      return email.replace('.','_').replace('.','_').replace('.','_')
                  .replace('.','_').replace('.','_').replace('.','_')
                  .replace('#','_').replace('$','_')
                  .replace('[','_').replace(']','_').replace('/','_');
    }

    function isOwner(userId) {
      return request.auth != null && (
        request.auth.uid == userId ||
        emailToId(request.auth.token.email) == userId
      );
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns true if the authenticated user's email appears in a flat email list.
    // Family documents store memberEmails (string[]) alongside the full members array
    // so Firestore rules can enforce membership without iterating over maps.
    function isFamilyMember(memberEmails) {
      return request.auth.token.email in memberEmails;
    }

    // ─── User documents ────────────────────────────────────────────────────
    // Owner reads/writes their own document only.
    // Leaderboard reads are scoped to a dedicated read-only projection (xp, name)
    // via the separate /leaderboard collection. Full progress docs are owner-only.
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ─── Leaderboard (public read, server-written projection) ─────────────
    // The app writes { name, xp, lc } here when saving progress.
    // Any authenticated user can read — no PII exposed.
    match /leaderboard/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // ─── Family groups ─────────────────────────────────────────────────────
    match /families/{familyCode} {
      // Any authenticated user can read (needed to validate join codes)
      allow read: if isAuthenticated();

      // Creator must be the sole initial member and include memberEmails for rule enforcement
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['name', 'code', 'created', 'members', 'memberEmails'])
        && request.resource.data.members.size() == 1
        && request.resource.data.memberEmails.size() == 1
        && request.auth.token.email in request.resource.data.memberEmails;

      // Only existing members can update (join/leave/rename).
      // memberEmails flat list enables O(1) membership check without map iteration.
      allow update: if isAuthenticated()
        && isFamilyMember(resource.data.memberEmails)
        && request.resource.data.keys().hasAll(['name', 'code', 'created', 'members', 'memberEmails'])
        && request.resource.data.members.size() <= 50
        && request.resource.data.memberEmails.size() <= 50
        && resource.data.created == request.resource.data.created
        && resource.data.code == request.resource.data.code;

      allow delete: if false;
    }

    // ─── Deny everything else ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
