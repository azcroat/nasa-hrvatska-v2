{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "numberOfRuns": 2,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance":     ["warn",  { "minScore": 0.75 }],
        "categories:accessibility":   ["error", { "minScore": 0.90 }],
        "categories:best-practices":  ["warn",  { "minScore": 0.90 }],
        "categories:seo":             ["warn",  { "minScore": 0.85 }],
        "categories:pwa":             ["warn",  { "minScore": 0.80 }],

        "first-contentful-paint":     ["warn",  { "maxNumericValue": 3000 }],
        "largest-contentful-paint":   ["warn",  { "maxNumericValue": 4500 }],
        "total-blocking-time":        ["warn",  { "maxNumericValue": 500  }],
        "cumulative-layout-shift":    ["warn",  { "maxNumericValue": 0.10 }],
        "speed-index":                ["warn",  { "maxNumericValue": 5000 }],

        "installable-manifest":       ["warn",  { "minScore": 1 }],
        "service-worker":             ["warn",  { "minScore": 1 }],
        "maskable-icon":              ["warn",  { "minScore": 1 }],
        "apple-touch-icon":           ["warn",  { "minScore": 1 }],
        "splash-screen":              ["warn",  { "minScore": 1 }],
        "themed-omnibox":             ["warn",  { "minScore": 1 }],
        "content-width":              ["warn",  { "minScore": 1 }],
        "viewport":                   ["error", { "minScore": 1 }],

        "is-on-https":                ["error", { "minScore": 1 }],
        "redirects-http":             ["warn",  { "minScore": 1 }],
        "uses-http2":                 ["warn",  { "minScore": 1 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
