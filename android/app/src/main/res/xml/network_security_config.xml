<?xml version="1.0" encoding="utf-8"?>
<!--
    network_security_config.xml — Naša Hrvatska Android network security policy.

    Enforces HTTPS-only traffic for all domains.
    Trusts only system certificate authorities (no user-installed CAs in release).
    Permits cleartext only for localhost during development (Capacitor live-reload).

    Reference: https://developer.android.com/training/articles/security-config
    Referenced from AndroidManifest.xml via android:networkSecurityConfig
-->
<network-security-config>

    <!-- Production: HTTPS only, system CAs only -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Firebase / Google APIs — HTTPS only, system CAs -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">firebaseapp.com</domain>
        <domain includeSubdomains="true">googleapis.com</domain>
        <domain includeSubdomains="true">cloudfunctions.net</domain>
        <domain includeSubdomains="true">nasa-hrvatska.pages.dev</domain>
        <domain includeSubdomains="true">elevenlabs.io</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!--
        Development only: allow Capacitor live-reload from localhost.
        This entry is harmless in release builds — localhost has no external surface.
        Remove this block if you want maximum strictness in release.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

</network-security-config>
