{
  "name": "nasa-hrvatska",
  "version": "2.0.0",
  "description": "Naša Hrvatska — Croatian Language & Culture Learning App",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "convert-images": "node scripts/convert-images.js",
    "prebuild": "node scripts/convert-images.js && node scripts/generate-icons.cjs && node scripts/generate-content-etags.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "npm run build && npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:report": "npx playwright show-report",
    "lint": "eslint src functions && npm run lint:croatian",
    "lint:fix": "eslint src functions --fix",
    "lint:croatian": "node scripts/lintCroatianText.mjs",
    "typecheck": "tsc --noEmit",
    "check:circular": "madge --circular --extensions ts,tsx,js,jsx src/",
    "size": "size-limit",
    "audit:pwa": "npx lhci autorun",
    "audit:store": "node -e \"console.log('Run: gh workflow run store-readiness.yml')\"",
    "prepare": "husky",
    "test:live": "npx playwright test --config playwright.stealth.config.js",
    "screenshots": "npx playwright test --config playwright.stealth.config.js e2e/screenshots.spec.js",
    "setup:cf": "node scripts/setup-cf-resources.mjs",
    "verify:firestore": "node scripts/verify-firestore.mjs",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run src/tests/firestore-rules.test.js\"",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run build && npx cap sync android && npx cap open android",
    "cap:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "cap:run:android": "npm run build && npx cap sync android && npx cap run android",
    "cap:run:ios": "npm run build && npx cap sync ios && npx cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "~8.3.0",
    "@capacitor/app": "~8.1.0",
    "@capacitor/browser": "~8.0.3",
    "@capacitor/cli": "~8.3.0",
    "@capacitor/core": "~8.3.0",
    "@capacitor/ios": "~8.3.0",
    "@capacitor/keyboard": "~8.0.2",
    "@capacitor/push-notifications": "~8.0.3",
    "@capacitor/splash-screen": "~8.0.1",
    "@capacitor/status-bar": "~8.0.2",
    "@sentry/react": "~10.42.0",
    "canvas-confetti": "~1.9.4",
    "dexie": "~4.3.0",
    "firebase": "~12.10.0",
    "framer-motion": "~12.38.0",
    "idb": "^8.0.3",
    "posthog-js": "~1.360.2",
    "react": "~18.3.1",
    "react-dom": "~18.3.1",
    "react-router-dom": "~6.30.3",
    "web-vitals": "~5.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^12.8.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^4.0.0",
    "fake-indexeddb": "^6.2.5",
    "firebase-admin": "^13.7.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "playwright-extra": "^4.3.6",
    "prettier": "^3.8.3",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.5",
    "size-limit": "^12.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "web-push": "^3.6.7"
  },
  "overrides": {
    "brace-expansion": ">=5.0.6",
    "serialize-javascript": ">=7.0.3",
    "undici": ">=7.24.0",
    "tmp": ">=0.2.4",
    "ws": ">=8.17.1",
    "tar": ">=6.2.1",
    "yaml": ">=2.8.3",
    "cacache": ">=18.0.5",
    "@tootallnate/once": ">=3.0.1",
    "basic-ftp": ">=5.2.1",
    "protobufjs": ">=7.5.8 <8"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --max-warnings=0"
    ],
    "functions/**/*.js": [
      "prettier --write",
      "eslint --max-warnings=0"
    ]
  },
  "size-limit": [
    {
      "name": "Initial JS (vendor-react + App entry)",
      "path": "dist/assets/vendor-react-*.js",
      "limit": "200 KB"
    },
    {
      "name": "Firebase bundle",
      "path": "dist/assets/vendor-firebase-*.js",
      "limit": "250 KB"
    },
    {
      "name": "Data chunk",
      "path": "dist/assets/chunk-data-*.js",
      "limit": "620 KB"
    }
  ]
}
