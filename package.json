{
  "name": "nasa-hrvatska",
  "version": "2.0.0",
  "description": "Naša Hrvatska — Croatian Language & Culture Learning App",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-icons.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:report": "npx playwright show-report",
    "lint": "eslint src functions",
    "lint:fix": "eslint src functions --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/react": "^10.42.0",
    "firebase": "^12.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jsdom": "^28.1.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.19.8",
    "vitest": "^4.0.18"
  }
}
