{
  "name": "nasa-hrvatska",
  "version": "2.0.0",
  "description": "Naša Hrvatska — Croatian Language & Culture Learning App",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-icons.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "npm run build && npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:report": "npx playwright show-report",
    "lint": "eslint src functions",
    "lint:fix": "eslint src functions --fix",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "audit:pwa": "npx lhci autorun",
    "audit:store": "node -e \"console.log('Run: gh workflow run store-readiness.yml')\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@sentry/react": "^10.42.0",
    "canvas-confetti": "^1.9.4",
    "dexie": "^4.3.0",
    "firebase": "^12.10.0",
    "posthog-js": "^1.360.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "sharp": "^0.34.5",
    "size-limit": "^12.0.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3",
    "undici": ">=7.24.0",
    "tmp": ">=0.2.4"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": "eslint --rule '{\"no-debugger\":\"error\",\"react-hooks/rules-of-hooks\":\"error\"}'",
    "functions/**/*.js": "eslint --max-warnings=0"
  },
  "size-limit": [
    {
      "name": "Initial JS (vendor-react + App entry)",
      "path": "dist/assets/vendor-react-*.js",
      "limit": "200 KB"
    },
    {
      "name": "Firebase bundle",
      "path": "dist/assets/vendor-firebase-*.js",
      "limit": "250 KB"
    },
    {
      "name": "Data chunk",
      "path": "dist/assets/chunk-data-*.js",
      "limit": "620 KB"
    }
  ]
}
