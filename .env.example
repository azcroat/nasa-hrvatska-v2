# Sentry error tracking (get DSN from sentry.io → Project → Settings → Client Keys)
VITE_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/123456

# Firebase (already configured in firebase-messaging-sw.js)
# These are safe to expose client-side (Firebase Web SDK design)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=   # Firebase Analytics (optional — G-XXXXXXXXXX from Firebase Console)

# PostHog product analytics (optional — get key from posthog.com, free up to 1M events/mo)
VITE_POSTHOG_KEY=

# App version for Sentry release tracking (e.g. 2.0.0)
VITE_APP_VERSION=
