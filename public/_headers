/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(self), geolocation=(), payment=(), usb=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Embedder-Policy: unsafe-none
  # 'unsafe-inline' was added in 2026-05-21 specifically to allow the Cloudflare
  # Web Analytics RUM beacon CF auto-injects on every request. The inline
  # bootstrap script body varies per version, so SHA256 hash whitelisting is
  # an unending game of whack-a-mole as CF rolls out new beacon builds. The
  # individual hashes we kept below cover the specific versions we observed
  # in May 2026 and remain as a fallback if 'unsafe-inline' is ever removed.
  #
  # PROPER LONG-TERM FIX: disable Cloudflare Web Analytics in the CF dashboard
  # (Analytics & Logs → Web Analytics → Off). We already use Plausible for
  # privacy-first analytics, so CF's beacon is redundant. Once disabled, the
  # inline scripts and the cloudflareinsights.com domain entry below can both
  # be removed and 'unsafe-inline' dropped to restore strict CSP. — JS, 5/21/26
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'sha256-ous+e24l7n7I+WjB5Hx/tMWna3lxJbKFXhW6ACuPwlI=' 'sha256-uh+jwqNVgO7Wb7bsMwLrChLpQpylOZ5dzpb/MBcOr8U=' 'sha256-JDvI+NDYCwu8M1BRuUTIgXLYy5Lh/Frx8SqyfWvcwD8=' https://www.gstatic.com/firebasejs/ https://*.firebaseapp.com https://*.googleapis.com https://apis.google.com https://plausible.io https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; media-src 'self' data: blob: https:; connect-src 'self' blob: https://*.firebaseio.com https://*.googleapis.com https://*.firebaseapp.com https://*.cloudfunctions.net https://*.cognitiveservices.azure.com wss://*.firebaseio.com https://*.posthog.com https://app.posthog.com https://*.ingest.sentry.io https://*.ingest.us.sentry.io https://sentry.io https://plausible.io https://cloudflareinsights.com; worker-src 'self' blob:; frame-src https://www.google.com https://www.youtube-nocookie.com https://www.youtube.com https://open.spotify.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/workbox-*.js
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.webmanifest
  Cache-Control: no-cache, no-store, must-revalidate

/version.json
  Cache-Control: no-cache, no-store, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/audio/*
  Cache-Control: public, max-age=31536000, immutable

# /api/* routes are handled by Cloudflare Pages Functions (functions/api/).
# CORS headers are set dynamically by the Function to echo the request Origin.
# Do NOT set static CORS headers here — they would override the Function's dynamic response.
